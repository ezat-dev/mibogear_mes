            <!-- tf_cycle_no는 지면 관계상 bcf 옆 칸에 표시 -->
            <!-- 실제로는 소려로패턴No 라벨 옆에 값 -->

            <!-- ================================================================
                 통합 온도 그래프 (사진 참고: 승온→침탄→확산→강온→소입→드레인→소려)
                 y=192 ~ y=430 (238px)

                 전체 폭 555px, 8구간:
                   승온:   x=0~60    (60px)
                   침탄:   x=60~155  (95px)
                   확산:   x=155~250 (95px)
                   강온:   x=250~330 (80px)
                   소입:   x=330~395 (65px)  ← 퀜칭
                   드레인: x=395~445 (50px)
                   소려(건조+팬업+N2+소려+냉각): x=445~555 (110px)

                 Y축 온도 매핑 (그래프 높이 160px, y=192~352):
                   고온(900℃)  → y=200 (그래프 상단 근처)
                   중온(830℃)  → y=220
                   저온(130℃)  → y=320 (소입)
                   소려(170℃)  → y=310
                   최저(0℃)    → y=352 (그래프 하단)
            ================================================================ -->

            <staticText>
                <reportElement x="0" y="192" width="555" height="16" uuid="44444444-4444-4444-4444-444444444401" backcolor="#EBF5FB"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="굴림" size="9" isBold="true" pdfFontName="fonts/gulim.ttf" pdfEncoding="Identity-H"/>
                </textElement>
                <text><![CDATA[열처리 패턴 온도 그래프 (BCF 침탄 → TF 소려)]]></text>
            </staticText>

            <!-- 그래프 외곽 박스 y=208~368 (160px) -->
            <rectangle>
                <reportElement x="0" y="208" width="555" height="160" uuid="44444444-4444-4444-4444-444444444402"/>
                <graphicElement><pen lineWidth="0.8"/></graphicElement>
            </rectangle>

            <!-- ── 온도 그래프 라인 ──
                 사진과 동일하게:
                 승온: 좌하→우상 대각선 (BottomUp)
                 침탄~확산: 최고점 수평
                 강온: 우하방 대각선 하강
                 소입(퀜칭): 급강 대각선
                 드레인: 저온 수평
                 소려: 삼각형(승온→수평→냉각)
            -->

            <!-- 승온: 저온→고온 상승 (BottomUp) x=5~60, y=215~360 -->
            <line direction="BottomUp">
