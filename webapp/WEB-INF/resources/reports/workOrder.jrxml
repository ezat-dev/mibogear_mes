    <title>
        <band height="780" splitType="Stretch">

            <!-- ===== 제목 + 바코드 (h=60) ===== -->
            <staticText>
                <reportElement x="0" y="0" width="340" height="40"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="굴림" size="16" isBold="true" pdfFontName="fonts/gulim.ttf" pdfEncoding="Identity-H"/>
                </textElement>
                <text><![CDATA[작  업  지  시  서]]></text>
            </staticText>
            <image scaleImage="RetainShape">
                <reportElement x="360" y="0" width="195" height="60"/>
