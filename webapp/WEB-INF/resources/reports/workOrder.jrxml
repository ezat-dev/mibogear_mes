<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="workOrder"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              language="groovy">

    <!-- ===== ЦФЖѓЙЬХЭ СЄРЧ ===== -->
    <parameter name="lot_no"                    class="java.lang.String"/>
    <parameter name="reg_date"                  class="java.lang.String"/>
    <parameter name="reg_user"                  class="java.lang.String"/>
    <parameter name="BARCODE_IMAGE"             class="java.awt.Image"/>

    <!-- main -->
    <parameter name="main_auto_pattern_number"  class="java.lang.String"/>
    <parameter name="main_yn"                   class="java.lang.String"/>
    <parameter name="main_bcf_pattern_number"   class="java.lang.String"/>
    <parameter name="main_tf_pattern_number"    class="java.lang.String"/>
    <parameter name="main_bcf_hogi"             class="java.lang.String"/>
    <parameter name="main_tf_hogi"              class="java.lang.String"/>
    <parameter name="main_spare_1"              class="java.lang.String"/>
    <parameter name="main_spare_2"              class="java.lang.String"/>
    <parameter name="main_spare_3"              class="java.lang.String"/>
    <parameter name="main_spare_4"              class="java.lang.String"/>
    <parameter name="main_bigo_1"               class="java.lang.String"/>
    <parameter name="main_bigo_2"               class="java.lang.String"/>
    <parameter name="main_bigo_3"               class="java.lang.String"/>
    <parameter name="main_bigo_4"               class="java.lang.String"/>
    <parameter name="main_bigo_5"               class="java.lang.String"/>

    <!-- upper -->
    <parameter name="upper_auto_pattern_number" class="java.lang.String"/>
    <parameter name="upper_yn"                  class="java.lang.String"/>
    <parameter name="upper_bcf_pattern_number"  class="java.lang.String"/>
    <parameter name="upper_tf_pattern_number"   class="java.lang.String"/>
    <parameter name="upper_bcf_hogi"            class="java.lang.String"/>
    <parameter name="upper_tf_hogi"             class="java.lang.String"/>
    <parameter name="upper_spare_1"             class="java.lang.String"/>
    <parameter name="upper_spare_2"             class="java.lang.String"/>
    <parameter name="upper_spare_3"             class="java.lang.String"/>
    <parameter name="upper_spare_4"             class="java.lang.String"/>
    <parameter name="upper_bigo_1"              class="java.lang.String"/>
    <parameter name="upper_bigo_2"              class="java.lang.String"/>
    <parameter name="upper_bigo_3"              class="java.lang.String"/>
    <parameter name="upper_bigo_4"              class="java.lang.String"/>
    <parameter name="upper_bigo_5"              class="java.lang.String"/>

    <!-- lower -->
    <parameter name="lower_auto_pattern_number" class="java.lang.String"/>
    <parameter name="lower_yn"                  class="java.lang.String"/>
    <parameter name="lower_bcf_pattern_number"  class="java.lang.String"/>
    <parameter name="lower_tf_pattern_number"   class="java.lang.String"/>
    <parameter name="lower_bcf_hogi"            class="java.lang.String"/>
    <parameter name="lower_tf_hogi"             class="java.lang.String"/>
    <parameter name="lower_spare_1"             class="java.lang.String"/>
    <parameter name="lower_spare_2"             class="java.lang.String"/>
    <parameter name="lower_spare_3"             class="java.lang.String"/>
    <parameter name="lower_spare_4"             class="java.lang.String"/>
    <parameter name="lower_bigo_1"              class="java.lang.String"/>
    <parameter name="lower_bigo_2"              class="java.lang.String"/>
    <parameter name="lower_bigo_3"              class="java.lang.String"/>
    <parameter name="lower_bigo_4"              class="java.lang.String"/>
    <parameter name="lower_bigo_5"              class="java.lang.String"/>

    <!-- belt -->
    <parameter name="belt_auto_pattern_number"  class="java.lang.String"/>
    <parameter name="belt_yn"                   class="java.lang.String"/>
    <parameter name="belt_bcf_pattern_number"   class="java.lang.String"/>
    <parameter name="belt_tf_pattern_number"    class="java.lang.String"/>
    <parameter name="belt_bcf_hogi"             class="java.lang.String"/>
    <parameter name="belt_tf_hogi"              class="java.lang.String"/>
    <parameter name="belt_spare_1"              class="java.lang.String"/>
    <parameter name="belt_spare_2"              class="java.lang.String"/>
    <parameter name="belt_spare_3"              class="java.lang.String"/>
    <parameter name="belt_spare_4"              class="java.lang.String"/>
    <parameter name="belt_bigo_1"               class="java.lang.String"/>
    <parameter name="belt_bigo_2"               class="java.lang.String"/>
    <parameter name="belt_bigo_3"               class="java.lang.String"/>
    <parameter name="belt_bigo_4"               class="java.lang.String"/>
    <parameter name="belt_bigo_5"               class="java.lang.String"/>

    <queryString><![CDATA[]]></queryString>

    <title>
        <band height="100" splitType="Stretch">

            <!-- СІИё -->
            <staticText>
                <reportElement x="0" y="0" width="340" height="30"/>
                <textElement verticalAlignment="Middle">
                    <font size="18" isBold="true" pdfFontName="HYGoThic-Medium"
                          pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <text><![CDATA[Рл  Ої  Сі  НУ  М­]]></text>
            </staticText>

            <!-- ЙйФкЕх РЬЙЬСі (ЛѓДм ПьУј) -->
            <image scaleImage="RetainShape" hAlign="Right">
                <reportElement x="360" y="0" width="175" height="60"/>
                <imageExpression><![CDATA[$P{BARCODE_IMAGE}]]></imageExpression>
            </image>

            <!-- LOTЙјШЃ ХиНКЦЎ (ЙйФкЕх ОЦЗЁ) -->
            <textField>
                <reportElement x="360" y="62" width="175" height="16"/>
                <textElement textAlignment="Center">
                    <font size="10" isBold="true" pdfFontName="HYGoThic-Medium"
                          pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <textFieldExpression><![CDATA["LOT: " + $P{lot_no}]]></textFieldExpression>
            </textField>

            <!-- ЕюЗЯРЯ / РлМКРк -->
            <textField>
                <reportElement x="0" y="34" width="340" height="16"/>
                <textElement>
                    <font size="9" pdfFontName="HYGoThic-Medium"
                          pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <textFieldExpression><![CDATA["ЕюЗЯРЯНУ : " + $P{reg_date} + "    РлМКРк : " + $P{reg_user}]]></textFieldExpression>
            </textField>

            <!-- БИКаМБ -->
            <line>
                <reportElement x="0" y="98" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <detail>
        <band height="580" splitType="Stretch">

            <!-- ===== МНМЧ ЧьДѕ АјХы НКХИРЯ СЄРЧПы ЧяЦл ===== -->

            <!-- Јч ФЇХКЗЮ КЛУМ УГИЎЧА ЧьДѕ -->
            <staticText>
                <reportElement x="0" y="6" width="535" height="18"
                               backcolor="#4A90D9" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isBold="true" textColor="white"
                          pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <text><![CDATA[ФЇХКЗЮ КЛУМ УГИЎЧА]]></text>
            </staticText>

            <!-- ФЇХКЗЮ КЛУМ - ЖѓКЇЧр -->
            <staticText><reportElement x="0"   y="26" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[РкЕПДыТї ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="89"  y="26" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[УГИЎЧА РЏ/ЙЋ]]></text></staticText>
            <staticText><reportElement x="178" y="26" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[ФЇХКЗЮ ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="267" y="26" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[МвЗСЗЮ ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="356" y="26" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[ФЇХКЗЮ ШЃБт]]></text></staticText>
            <staticText><reportElement x="445" y="26" width="90" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[МвЗСЗЮ ШЃБт]]></text></staticText>

            <!-- ФЇХКЗЮ КЛУМ - АЊЧр -->
            <textField><reportElement x="0"   y="40" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_auto_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="89"  y="40" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_yn}]]></textFieldExpression></textField>
            <textField><reportElement x="178" y="40" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_bcf_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="267" y="40" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_tf_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="356" y="40" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_bcf_hogi}]]></textFieldExpression></textField>
            <textField><reportElement x="445" y="40" width="90" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{main_tf_hogi}]]></textFieldExpression></textField>

            <!-- ФЇХКЗЮ КЛУМ - НКЦфОю/КёАэ -->
            <staticText><reportElement x="0" y="56" width="535" height="14" backcolor="#fffde7" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Left" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[  НКЦфОю/КёАэ]]></text></staticText>
            <textField isStretchWithOverflow="true"><reportElement x="0" y="70" width="535" height="14"/><box><pen lineWidth="0.5"/></box><textElement verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement>
                <textFieldExpression><![CDATA["  S1:" + ($P{main_spare_1} != null ? $P{main_spare_1} : "") + "  S2:" + ($P{main_spare_2} != null ? $P{main_spare_2} : "") + "  S3:" + ($P{main_spare_3} != null ? $P{main_spare_3} : "") + "  S4:" + ($P{main_spare_4} != null ? $P{main_spare_4} : "")]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true"><reportElement x="0" y="84" width="535" height="14"/><box><pen lineWidth="0.5"/></box><textElement verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement>
                <textFieldExpression><![CDATA["  Кё1:" + ($P{main_bigo_1} != null ? $P{main_bigo_1} : "") + "  Кё2:" + ($P{main_bigo_2} != null ? $P{main_bigo_2} : "") + "  Кё3:" + ($P{main_bigo_3} != null ? $P{main_bigo_3} : "") + "  Кё4:" + ($P{main_bigo_4} != null ? $P{main_bigo_4} : "") + "  Кё5:" + ($P{main_bigo_5} != null ? $P{main_bigo_5} : "")]]></textFieldExpression>
            </textField>

            <!-- Јш РЏСЖ E/V УМРЮ (ЛѓКЮ) -->
            <staticText>
                <reportElement x="0" y="106" width="535" height="18"
                               backcolor="#00BCD4" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isBold="true" textColor="white"
                          pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <text><![CDATA[РЏСЖ E/V УМРЮ (ЛѓКЮ) УГИЎЧА]]></text>
            </staticText>
            <staticText><reportElement x="0"   y="126" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[РкЕПДыТї ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="89"  y="126" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[УГИЎЧА РЏ/ЙЋ]]></text></staticText>
            <staticText><reportElement x="178" y="126" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[ФЇХКЗЮ ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="267" y="126" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[МвЗСЗЮ ЦаХЯЙјШЃ]]></text></staticText>
            <staticText><reportElement x="356" y="126" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[ФЇХКЗЮ ШЃБт]]></text></staticText>
            <staticText><reportElement x="445" y="126" width="90" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[МвЗСЗЮ ШЃБт]]></text></staticText>
            <textField><reportElement x="0"   y="140" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_auto_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="89"  y="140" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_yn}]]></textFieldExpression></textField>
            <textField><reportElement x="178" y="140" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_bcf_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="267" y="140" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_tf_pattern_number}]]></textFieldExpression></textField>
            <textField><reportElement x="356" y="140" width="89" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_bcf_hogi}]]></textFieldExpression></textField>
            <textField><reportElement x="445" y="140" width="90" height="14"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><textFieldExpression><![CDATA[$P{upper_tf_hogi}]]></textFieldExpression></textField>
            <staticText><reportElement x="0" y="156" width="535" height="14" backcolor="#fffde7" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Left" verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[  НКЦфОю/КёАэ]]></text></staticText>
            <textField isStretchWithOverflow="true"><reportElement x="0" y="170" width="535" height="14"/><box><pen lineWidth="0.5"/></box><textElement verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement>
                <textFieldExpression><![CDATA["  S1:" + ($P{upper_spare_1} != null ? $P{upper_spare_1} : "") + "  S2:" + ($P{upper_spare_2} != null ? $P{upper_spare_2} : "") + "  S3:" + ($P{upper_spare_3} != null ? $P{upper_spare_3} : "") + "  S4:" + ($P{upper_spare_4} != null ? $P{upper_spare_4} : "")]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true"><reportElement x="0" y="184" width="535" height="14"/><box><pen lineWidth="0.5"/></box><textElement verticalAlignment="Middle"><font size="8" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement>
                <textFieldExpression><![CDATA["  Кё1:" + ($P{upper_bigo_1} != null ? $P{upper_bigo_1} : "") + "  Кё2:" + ($P{upper_bigo_2} != null ? $P{upper_bigo_2} : "") + "  Кё3:" + ($P{upper_bigo_3} != null ? $P{upper_bigo_3} : "") + "  Кё4:" + ($P{upper_bigo_4} != null ? $P{upper_bigo_4} : "") + "  Кё5:" + ($P{upper_bigo_5} != null ? $P{upper_bigo_5} : "")]]></textFieldExpression>
            </textField>

            <!-- Јщ РЏСЖ E/V УМРЮ (ЧЯКЮ) -->
            <staticText>
                <reportElement x="0" y="206" width="535" height="18"
                               backcolor="#00BCD4" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="10" isBold="true" textColor="white"
                          pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/>
                </textElement>
                <text><![CDATA[РЏСЖ E/V УМРЮ (ЧЯКЮ) УГИЎЧА]]></text>
            </staticText>
            <staticText><reportElement x="0"   y="226" width="89" height="14" backcolor="#f0f0f0" mode="Opaque"/><box><pen lineWidth="0.5"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true" pdfFontName="HYGoThic-Medium" pdfEncoding="UniKS-UCS2-H" isPdfEmbedded="false"/></textElement><text><![CDATA[РкЕПДыТї ЦаХЯЙјШЃ]]></text></staticText>
